# API Configuration
API_BASE_URL=http://localhost:8000/api
API_TIMEOUT=30

# App Information
APP_NAME=Needs
APP_VERSION=1.0.0

# Environment Configuration
IS_DEVELOPMENT=true

# Payment Configuration - Alipay
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_SANDBOX_URL=https://openapi.alipaydev.com/gateway.do
ALIPAY_PRODUCTION_URL=https://openapi.alipay.com/gateway.do

# AI Configuration - Deepseek
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Logging
ENABLE_LOGGING=true

# Features
ENABLE_PAYMENT=true
ENABLE_AI_ASSISTANT=true
ENABLE_IMAGE_UPLOAD=true

# Local Storage
STORAGE_BOX_NAME=needs_storage
